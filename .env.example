# Street2Ivy / Proveground — Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables marked (required) must be set for the app to start.
# Variables marked (optional) enable extra features when provided.

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

# PostgreSQL connection string (required)
# On Heroku this is set automatically by the Heroku Postgres addon.
DATABASE_URL=postgres://user:password@host:5432/database

# ──────────────────────────────────────────────
# App Configuration
# ──────────────────────────────────────────────

# Public-facing URL of the application (required)
# Used for email links, metadata, portfolio share URLs, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Heroku app name — used by CI/CD deploy workflow (optional)
HEROKU_APP_NAME=street2ivy-dev

# Server port — defaults to 3000 (optional, set automatically on Heroku)
# PORT=3000

# ──────────────────────────────────────────────
# Tenant / Multi-tenancy
# ──────────────────────────────────────────────

# Default tenant UUID — used when no subdomain is detected (required)
TENANT_ID=your-tenant-uuid

# ──────────────────────────────────────────────
# Security / Encryption
# ──────────────────────────────────────────────

# AES-256 encryption key for Handshake API key storage (required for Handshake integration)
# Can be any string — it is SHA-256 hashed to derive the actual 32-byte key.
ENCRYPTION_KEY=

# Secret token to authorize cron job endpoints (required for cron routes)
# Set to a random string; cron requests must send this in the Authorization header.
CRON_SECRET=

# ──────────────────────────────────────────────
# Email (Mailgun)
# ──────────────────────────────────────────────

# Mailgun API key (optional — emails are disabled if not set)
MAILGUN_API_KEY=

# Mailgun sending domain (optional, defaults to mg.proveground.com)
MAILGUN_DOMAIN=

# Sender display name for legacy email templates (optional, defaults to "Proveground")
MAILGUN_FROM_NAME=Proveground

# Sender email for legacy email templates (optional, defaults to noreply@MAILGUN_DOMAIN)
MAILGUN_FROM_EMAIL=noreply@proveground.com

# Formatted "From" address for the new email client (optional)
# Example: "Proveground <noreply@proveground.com>"
FROM_EMAIL=Proveground <noreply@proveground.com>

# Master switch to disable all email sending (optional, defaults to auto-detect)
EMAIL_ENABLED=true

# ──────────────────────────────────────────────
# AI Services (Anthropic Claude)
# ──────────────────────────────────────────────

# Anthropic API key for AI features (optional — AI features disabled if not set)
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# Media / File Uploads (Cloudinary)
# ──────────────────────────────────────────────

# Cloudinary credentials (optional — media uploads disabled if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────

# Redis connection URL (optional — falls back to in-memory if not set)
# Heroku sets REDIS_URL or REDIS_TLS_URL automatically.
REDIS_URL=redis://localhost:6379
# REDIS_TLS_URL=  # Used by Heroku Premium/Private plans (rediss:// protocol)

# ──────────────────────────────────────────────
# Monitoring (Sentry)
# ──────────────────────────────────────────────

# Sentry DSN — enables error tracking when set (optional, no-op if empty)
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=  # Server-side only DSN (falls back to NEXT_PUBLIC_SENTRY_DSN)

# Sentry organization and project slugs — used for source map uploads (optional)
SENTRY_ORG=
SENTRY_PROJECT=
